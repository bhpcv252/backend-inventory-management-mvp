generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
}

model Organization {
  id                       String   @id @default(uuid())
  name                     String
  defaultLowStockThreshold Int      @default(5)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  users          User[]
  products       Product[]
  stockMovements StockMovement[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  role           UserRole     @default(OWNER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  stockMovements StockMovement[]
}

model Product {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name              String
  sku               String
  description       String?
  costPrice         Float?
  sellingPrice      Float?
  lowStockThreshold Int?

  // CACHE FIELD
  quantityOnHand Int @default(0)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stockMovements StockMovement[]

  // It is being handled by partial sku index
  // @@unique([organizationId, sku])
}

model StockMovement {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])

  delta          Int     // positive = stock in, negative = stock out
  note           String?
  idempotencyKey String? @unique // DB-level safety net

  createdAt DateTime @default(now())
}

model IdempotencyRecord {
  id             String   @id @default(uuid())
  key            String   @unique
  organizationId String
  responseBody   Json
  statusCode     Int
  createdAt      DateTime @default(now())
  expiresAt      DateTime // 24 h from creation 
}
